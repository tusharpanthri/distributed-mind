MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_OUTPUT=processed-data

# botocore >=1.36 defaults to checksum headers MinIO's S3 API (older release)
# doesn't accept on bulk-delete/overwrite calls (used by Dask's to_parquet).
# These restore the pre-1.36 opt-in behavior.
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required
